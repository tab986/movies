# Prefer a single root `.env` (repo root); Vite is configured with envDir `..` so these load from there too.
#
# VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# VITE_SUPABASE_ANON_KEY=<anon public key from Supabase → Settings → API>
#
# Optional. Leave unset to use same-origin /api (Vite dev proxy → Express).
# VITE_API_URL=http://localhost:5000/api
