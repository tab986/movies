# Server
PORT=5000
NODE_ENV=production

# Postgres — user postgres, URL-encode special chars in password (@ → %40, ! → %21)
# Local: postgresql://postgres:Postgres%402026%21Pass@localhost:5432/movies
# Coolify internal: postgresql://postgres:Postgres%402026%21Pass@<postgres-host>:5432/movies
DATABASE_URL=

# TMDB — https://www.themoviedb.org/settings/api
TMDB_READ_ACCESS_TOKEN=
TMDB_API_KEY=
