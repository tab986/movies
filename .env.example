# Architecture: Supabase (Postgres + Auth) · Node.js (this API + business logic)

# Server
PORT=5000
NODE_ENV=production

# Supabase Postgres — Project Settings → Database → Connection string
DATABASE_URL=

# Verify Supabase access tokens on /api (Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=

# Frontend (Vite) — required at Docker build time on Coolify
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# VITE_SUPABASE_PUBLISHABLE_KEY=   # alias for anon key

# TMDB — https://www.themoviedb.org/settings/api
TMDB_READ_ACCESS_TOKEN=
TMDB_API_KEY=
