# =============================================================================
# GameWise API — environment template (copy to .env; never commit real values)
# =============================================================================

# --- Server ---
NODE_ENV=production
PORT=5000

# --- PostgreSQL (Supabase, Coolify Postgres, or Contabo VPS) ---
# Use one URI; sslmode=require is typical for managed Postgres.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require
# Or discrete fields (used when DATABASE_URL is unset):
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=postgres
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
POSTGRES_SSL=true

# First deploy on a fresh DB: create tables once, then set false.
DB_INIT_ON_STARTUP=true
# Exit container if DB schema is missing (strict prod); false = degraded mode.
EXIT_ON_STARTUP_DB_FAILURE=false

# --- Auth ---
JWT_SECRET=change-me-long-random-string
JWT_EXPIRES_IN=90d
JWT_COOKIE_EXPIRES_IN=90
ADMIN_PASSWORD=change-me-admin-signup-password

# Supabase (if using Supabase Auth from a separate frontend)
SUPABASE_JWT_SECRET=

# --- CORS / storefront ---
CORS_ALLOWED_ORIGINS=https://www.gamewiseiq.com,https://gamewiseiq.com
FRONTEND_URL=https://www.gamewiseiq.com
STOREFRONT_PUBLIC_URL=https://www.gamewiseiq.com

# --- Kinguin ESA ---
KINGUIN_API_BASE=https://gateway.kinguin.net/esa/api
KINGUIN_API_KEY=

# --- Wayl payments ---
WAYL_AUTH_KEY=
WAYL_BASE=https://api.thewayl.com/api/v1
WAYL_SECRET=
WAYL_WEBHOOK_URL=https://your-api.example.com/api/v1/orders/wayl-callback
WAYL_REDIRECT_URL=https://www.gamewiseiq.com/my-orders

# --- Twilio OTP ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SID=

# --- Cloudflare R2 (image uploads) ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET_PATH=
AWS_REGION=auto

# --- Cloudflare analytics (optional dashboard route) ---
CF_ZONE_ID=
CF_API_TOKEN=

# --- IsThereAnyDeal (official store price comparison) ---
ITAD_API_KEY=
ITAD_DEFAULT_COUNTRY=US

# --- Sync workers ---
SYNC_PAGE_SIZE=100
SYNC_CONCURRENCY=10
SYNC_OVERLAP_MINUTES=10
SYNC_SCHEDULE=0 5 * * *
ENABLE_INTERNAL_SCHEDULER=true

# --- Pricing ---
EUR_TO_IQD=1535
IQD_MARKUP=5800

# --- Webhooks ---
WEBHOOK_SECRET=

# --- Optional: post-deploy validation script ---
# POST_DEPLOY_BASE_URL=https://your-api.example.com
